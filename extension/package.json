{
  "name": "commitver",
  "displayName": "COMMITVER",
  "description": "Simple commit with automatic versioning",
  "version": "1.0.0",
  "publisher": "commitver",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:commitver.quickCommit"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitver.quickCommit",
        "title": "Quick Commit with Version",
        "category": "COMMITVER"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "commitver.quickCommit"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}
